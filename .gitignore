# Internal working docs (kept locally for session-to-session continuity,
# not pushed to the public repo per user instruction). TODO.md is tracked
# and pushed as the project's public task list; PROGRESS.md is private.
CLAUDE.md
PROGRESS.md

# Python
venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Data (gitignored per CLAUDE.md section 6 — datasets are downloaded, not committed)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Databases (Module B state store output)
*.db
*.duckdb

# Pretrained weights (auto-downloaded by ultralytics on first run), and
# any locally fine-tuned checkpoint. weights/soccersum_yolov8n_ball.pt is
# NOT committed: it's fine-tuned on SoccerSum, which is CC BY-NC-ND
# (No-Derivatives) -- distributing a derivative model trained on it is a
# real licensing risk for a public repo. Run
# `python -m notebooks.finetune_ball_detector train` against your own
# SoccerSum download to regenerate it locally; yolo_detector.py falls back
# to plain pretrained COCO weights if the file isn't present.
*.pt

# Vector store persistence (Module C)
.chroma/
*.index

# Reports build artifacts
reports/paper/*.aux
reports/paper/*.log
reports/paper/*.out
reports/paper/*.pdf

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Env
.env
